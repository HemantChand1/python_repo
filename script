pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo '📥 Pulling code from Git...'
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                echo '📦 Installing pandas...'
                sh 'pip install -r requirements.txt --break-system-packages'
            }
        }

        stage('Run Analysis') {
            steps {
                echo '🔍 Running Student Study Analysis...'
                sh 'python3 src/analysis.py'
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Running Unit Tests...'
                sh 'python3 -m unittest discover src'
            }
        }

        stage('Show Results') {
            steps {
                echo '📊 Displaying Results...'
                sh 'cat output/results.txt'
            }
        }

        stage('Save Results') {
            steps {
                echo '💾 Archiving results...'
                archiveArtifacts artifacts: 'output/results.txt',
                                 fingerprint: true
            }
        }
    }

    post {
        success {
            echo '✅ Analysis Complete!'
        }
        failure {
            echo '❌ Pipeline Failed — Check logs!'
        }
    }
}
